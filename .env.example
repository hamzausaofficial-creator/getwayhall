# Django
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database (PostgreSQL) — Railway auto-sets DATABASE_URL when you add Postgres plugin
DATABASE_URL=
DB_SSL=true
DB_NAME=hallora
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF — optional; *.vercel.app and Railway domain are auto-allowed in code
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app,https://getwayhall-production.up.railway.app
#
# Local Docker deployment (see deploy/.env.example):
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Railway API-only (frontend on Vercel) — required on Railway backend service
SERVE_FRONTEND=false

# Optional Cloudinary for persistent uploads on Railway (recommended)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Without this, uploaded files are lost on each Railway redeploy.
#
# Alternative: attach a Railway Volume to the backend service at:
#   /app/backend/media
# Railway sets RAILWAY_VOLUME_MOUNT_PATH automatically when a volume is attached.

# Notifications: console (dev) | twilio (live SMS/WhatsApp)
NOTIFICATION_BACKEND=console

# Twilio (when NOTIFICATION_BACKEND=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# -----------------------------------------------------------------------------
# Windows local deployment (Docker) — see deploy/.env.example and README_DEPLOYMENT.md
# Copy deploy/.env.example to deploy/.env for the client laptop setup.
# -----------------------------------------------------------------------------
# USE_HTTPS=false
# LOG_LEVEL=INFO
