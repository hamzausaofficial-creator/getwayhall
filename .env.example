# Django
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database (PostgreSQL) — Railway auto-sets DATABASE_URL when you add Postgres plugin
DATABASE_URL=
DB_SSL=true
DB_NAME=hallora
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS / CSRF — set your Vercel frontend URL after deploy
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# Frontend (Vercel) — set in Vercel dashboard, not backend
# VITE_API_BASE_URL=https://your-backend.up.railway.app/api

# Notifications: console (dev) | twilio (live SMS/WhatsApp)
NOTIFICATION_BACKEND=console

# Twilio (when NOTIFICATION_BACKEND=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
