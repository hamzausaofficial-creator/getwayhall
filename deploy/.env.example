# =============================================================================
# Gateway Marriage Hall — Windows deployment environment
# Copy this file to deploy/.env and fill in the values before first start.
# =============================================================================

# --- Application ---
# Port exposed on the client laptop (default 8080 avoids Windows port 80 conflicts)
APP_PORT=8080

# Django secret key — generate a long random string for production
# Example (PowerShell): [System.Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
SECRET_KEY=change-me-to-a-long-random-string

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS / CSRF — required for Django admin login over HTTP (update port if APP_PORT changes)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost,http://127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost,http://127.0.0.1

# Set true only on the very first install to create admin users and landing content
RUN_SEED_ON_START=true

# --- PostgreSQL (stored in a persistent Docker volume) ---
DB_NAME=hallora
DB_USER=hallora
DB_PASSWORD=change-me-strong-db-password

# --- Frontend build ---
# API base URL baked into the React build (keep as /api for local Docker)
VITE_API_BASE_URL=/api

# --- Gunicorn ---
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# --- Logging ---
LOG_LEVEL=INFO

# --- Git update (used by update script) ---
GIT_BRANCH=main

# --- Notifications (optional) ---
NOTIFICATION_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
